							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.environment.set(\"sales_token_1\", jsonData.token);",
									"    pm.environment.set(\"token\", jsonData.token);",
									"    pm.globals.set(\"token\", jsonData.token);",
