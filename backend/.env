# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Swap this with your MongoDB Atlas Connection String
MONGO_URI=mongodb://127.0.0.1:27017/gigflow

# Security (JWT Auth)
JWT_SECRET=gigflow_dev_secret_key_987654321
JWT_EXPIRES_IN=7d

# CORS Configuration (Vite's default port is 5173)
CORS_ORIGIN=http://localhost:5173
